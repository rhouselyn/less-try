# 服务器配置
HOST=0.0.0.0
PORT=8000

# 数据和配置目录（默认为项目根目录下的 data/ 和 config/）
# BASE_DIR=/workspace
# DATA_DIR=/workspace/data
# CONFIG_DIR=/workspace/config

# 前端静态文件目录（生产部署时使用，npm run build 后的输出目录）
# FRONTEND_DIST_DIR=/workspace/frontend/dist

# LLM API 配置说明：
# API Key、Base URL、Model 等配置请在界面右上角 ⚙️ 设置中配置，
# 支持多组配置轮询，数据保存在 config/llm_settings.json 中。
